@host=http://localhost:8080

### ---------------------------- ###
###        User Types            ###
### ---------------------------- ###

### Create User Type Owner
# @name userTypeOwner
POST {{host}}/api/v1/user-types
Content-Type: application/json

{
  "name": "Restaurant Owner",
  "description": "User responsible for managing a restaurant.",
  "role": "RESTAURANT_OWNER"
}

### Create User Type Customer
# @name userTypeCustomer
POST {{host}}/api/v1/user-types
Content-Type: application/json

{
  "name": "Customer",
  "description": "User who can browse restaurants and place orders.",
  "role": "CUSTOMER"
}

### Create User Type Admin
# @name userTypeAdmin
POST {{host}}/api/v1/user-types
Content-Type: application/json

{
  "name": "Administrator",
  "description": "User who can management restaurants",
  "role": "ADMIN"
}

### GET USERS TYPES
GET {{host}}/api/v1/user-types
###
DELETE {{host}}/api/v1/user-types/7b18357e-c68b-4f16-ae4c-795ce3cc713f

### ---------------------------- ###
###           Users              ###
### ---------------------------- ###


### Restaurant Owner 1
# @name userOwner_1
POST {{host}}/api/v1/users
Content-Type: application/json

{
  "name": "Alistair Cockburn",
  "email": "alistair@mail.com",
  "password": "password123",
  "userTypeId": "{{userTypeOwner.response.body.id}}"
}

